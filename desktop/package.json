{
  "name": "voiceforge-desktop",
  "version": "0.2.0-alpha.2",
  "private": true,
  "description": "VoiceForge desktop UI (Tauri + D-Bus)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "e2e": "playwright test",
    "e2e:gate": "playwright test e2e/nav.spec.js e2e/autopilot.spec.js e2e/a11y.spec.js e2e/visual.spec.js",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:update-snapshots": "playwright test --update-snapshots",
    "e2e:native": "npm --prefix e2e-native ci && npm --prefix e2e-native run test",
    "e2e:native:headless": "npm --prefix e2e-native ci && npm --prefix e2e-native run test:headless",
    "e2e:release-gate": "npm run build && npm run e2e:gate",
    "tauri": "tauri",
    "tauri:build": "tauri build"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/test": "^1.49.0",
    "@tauri-apps/cli": "^2",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-deep-link": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "chart.js": "^4"
  }
}
